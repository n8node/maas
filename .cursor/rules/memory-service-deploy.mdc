## Деплой

### Первый деплой (ручной)

```bash
# На сервере:

# 1. Склонировать репо
cd /opt
git clone git@github.com:{username}/memory-service.git
cd memory-service

# 2. Создать .env из примера и заполнить
cp .env.example .env
nano .env
# ОБЯЗАТЕЛЬНО заполнить:
# - POSTGRES_PASSWORD (сгенерировать: openssl rand -base64 32)
# - WP_DB_PASSWORD (сгенерировать: openssl rand -base64 32)
# - WP_DB_ROOT_PASSWORD (сгенерировать: openssl rand -base64 32)
# - JWT_SECRET (сгенерировать: openssl rand -base64 64)
# - API_KEY_SALT (сгенерировать: openssl rand -base64 32)
# - OPENROUTER_API_KEY (из OpenRouter dashboard)
# - ENVIRONMENT=production

# 3. Получить SSL-сертификат (Let's Encrypt)
# Сначала запустить без SSL чтобы certbot мог верифицировать домен
make prod

# Остановить и получить сертификат
docker compose -f docker-compose.yml -f docker-compose.prod.yml down
sudo apt install certbot -y
sudo certbot certonly --standalone -d mnemoniqa.com -d www.mnemoniqa.com
sudo cp /etc/letsencrypt/live/mnemoniqa.com/fullchain.pem nginx/ssl/
sudo cp /etc/letsencrypt/live/mnemoniqa.com/privkey.pem nginx/ssl/

# 4. Включить SSL в nginx конфиге
# Раскомментировать SSL server block в nginx/conf.d/default.conf
# Раскомментировать HTTP→HTTPS redirect

# 5. Запустить production
make prod

# 6. Применить миграции
make migrate

# 7. Создать суперадмина
docker compose -f docker-compose.yml -f docker-compose.prod.yml exec backend \
  ./server --seed-admin --email=admin@mnemoniqa.com --password=CHANGE_ME

# 8. Проверить
curl https://mnemoniqa.com/health
# {"status":"ok","version":"0.1.0"}
```

### Последующие деплои

```bash
# На сервере:
cd /opt/memory-service
git pull origin main
make prod
# Docker Compose пересоберёт только изменившиеся контейнеры

# Если есть новые миграции:
make migrate
```

### Скрипт деплоя (scripts/deploy.sh)

```bash
#!/bin/bash
set -e

# Настройки
SERVER="deploy@{server_ip}"
PROJECT_DIR="/opt/memory-service"
BRANCH="${1:-main}"

echo "=== Deploying branch: $BRANCH ==="

# 1. Push локальные изменения
git push origin $BRANCH

# 2. Деплой на сервер
ssh $SERVER << EOF
  set -e
  cd $PROJECT_DIR
  
  echo ">>> Pulling latest code..."
  git fetch origin
  git checkout $BRANCH
  git pull origin $BRANCH
  
  echo ">>> Building and starting containers..."
  docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build -d
  
  echo ">>> Running migrations..."
  docker compose -f docker-compose.yml -f docker-compose.prod.yml exec -T backend \
    goose -dir ./migrations postgres "\$DATABASE_URL" up
  
  echo ">>> Cleaning old images..."
  docker image prune -f
  
  echo ">>> Health check..."
  sleep 5
  curl -sf https://mnemoniqa.com/health || echo "WARNING: Health check failed!"
  
  echo ">>> Done!"
EOF

echo "=== Deploy complete ==="
```

Использование:
```bash
chmod +x scripts/deploy.sh
./scripts/deploy.sh          # деплоит main
./scripts/deploy.sh develop  # деплоит develop
```

### Makefile (дополнение)

```makefile
# Деплой
deploy:
	./scripts/deploy.sh main

deploy-dev:
	./scripts/deploy.sh develop

# SSL
ssl-renew:
	docker compose -f docker-compose.yml -f docker-compose.prod.yml exec nginx certbot renew
	docker compose -f docker-compose.yml -f docker-compose.prod.yml exec nginx nginx -s reload

# Бэкапы
backup-db:
	docker compose exec postgres pg_dump -U memoryservice memoryservice | gzip > backups/pg_$(shell date +%Y%m%d_%H%M%S).sql.gz

backup-wp:
	docker compose exec mysql mysqldump -u wordpress -p wordpress | gzip > backups/wp_$(shell date +%Y%m%d_%H%M%S).sql.gz

# Логи production
logs-prod:
	docker compose -f docker-compose.yml -f docker-compose.prod.yml logs -f

# Статус
status:
	docker compose -f docker-compose.yml -f docker-compose.prod.yml ps
```

