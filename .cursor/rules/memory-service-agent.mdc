## Миграции

```sql
-- migrations/010_agents.up.sql

CREATE TABLE agents (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    name TEXT NOT NULL,
    description TEXT DEFAULT '',
    config JSONB NOT NULL DEFAULT '{
        "synthesis_model": "anthropic/claude-sonnet-4",
        "merge_strategy": "weighted",
        "max_context_tokens": 8000
    }',
    status TEXT DEFAULT 'active' CHECK (status IN ('active', 'paused', 'deleted')),
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

CREATE INDEX agents_user_idx ON agents(user_id);

CREATE TABLE agent_layers (
    agent_id UUID REFERENCES agents(id) ON DELETE CASCADE,
    instance_id UUID REFERENCES memory_instances(id) ON DELETE CASCADE,
    role TEXT NOT NULL,                     -- "knowledge_base", "user_history", "session", "psychology", "graph", "compiler"
    priority INT NOT NULL DEFAULT 1,       -- Порядок обхода
    enabled BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ DEFAULT now(),
    PRIMARY KEY (agent_id, instance_id)
);

-- Constraint: один тип памяти = один слой в агенте
CREATE UNIQUE INDEX agent_layers_type_unique
    ON agent_layers(agent_id, (
        SELECT memory_type FROM memory_instances WHERE id = instance_id
    ));
-- NOTE: этот constraint реализуется на уровне Go service, не в SQL
-- (PostgreSQL не поддерживает подзапросы в unique index)

-- Добавить ссылку на agent в memory_instances (nullable, standalone = NULL)
ALTER TABLE memory_instances ADD COLUMN agent_id UUID REFERENCES agents(id) ON DELETE SET NULL;
CREATE INDEX instances_agent_idx ON memory_instances(agent_id) WHERE agent_id IS NOT NULL;

-- Usage log для agent-level query (synthesis)
-- Используется та же таблица usage_log, с operation = 'agent_query_synthesis'
-- и instance_id = NULL, но добавляется agent_id
ALTER TABLE usage_log ADD COLUMN agent_id UUID REFERENCES agents(id);
```

