## Дополнительные таблицы БД (к основным из rules файла)

```sql
-- Тарифные планы
CREATE TABLE plans (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    slug TEXT UNIQUE NOT NULL,
    price_monthly_rub INT NOT NULL DEFAULT 0,
    price_yearly_rub INT NOT NULL DEFAULT 0,
    max_instances INT NOT NULL DEFAULT 2,
    monthly_tokens BIGINT NOT NULL DEFAULT 100000,
    max_storage_mb BIGINT NOT NULL DEFAULT 100,
    allowed_memory_types TEXT[] NOT NULL DEFAULT '{rag}',
    gardener_enabled BOOLEAN DEFAULT false,
    reflective_enabled BOOLEAN DEFAULT false,
    bi_temporal_enabled BOOLEAN DEFAULT false,
    custom_models BOOLEAN DEFAULT false,
    priority_workers BOOLEAN DEFAULT false,
    support_level TEXT DEFAULT 'community',
    is_public BOOLEAN DEFAULT true,
    is_archived BOOLEAN DEFAULT false,
    sort_order INT DEFAULT 0,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

-- Пакеты токенов
CREATE TABLE token_packages (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    tokens BIGINT NOT NULL,
    price_rub INT NOT NULL,
    is_active BOOLEAN DEFAULT true,
    sort_order INT DEFAULT 0,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- Подписки пользователей
CREATE TABLE subscriptions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    plan_id UUID REFERENCES plans(id),
    status TEXT DEFAULT 'active' CHECK (status IN ('active', 'canceled', 'past_due', 'paused')),
    current_period_start TIMESTAMPTZ NOT NULL,
    current_period_end TIMESTAMPTZ NOT NULL,
    cancel_at_period_end BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

-- Баланс токенов
CREATE TABLE token_balances (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    source TEXT NOT NULL CHECK (source IN ('plan', 'purchase', 'bonus', 'promo')),
    source_id UUID,                    -- plan_id, package purchase id, promo_id
    tokens_total BIGINT NOT NULL,
    tokens_used BIGINT DEFAULT 0,
    expires_at TIMESTAMPTZ,            -- plan tokens expire at period end
    created_at TIMESTAMPTZ DEFAULT now(),
    CONSTRAINT positive_balance CHECK (tokens_used <= tokens_total)
);

CREATE INDEX token_balances_user_idx ON token_balances(user_id, created_at);

-- Платежи
CREATE TABLE payments (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id),
    type TEXT NOT NULL CHECK (type IN ('subscription', 'token_package')),
    amount_kopecks INT NOT NULL,       -- Сумма в копейках
    currency TEXT DEFAULT 'RUB',
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'completed', 'failed', 'refunded')),
    plan_id UUID REFERENCES plans(id),
    package_id UUID REFERENCES token_packages(id),
    external_id TEXT,                  -- ID в платёжной системе
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMPTZ DEFAULT now(),
    completed_at TIMESTAMPTZ
);

-- Промокоды
CREATE TABLE promocodes (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    code TEXT UNIQUE NOT NULL,
    type TEXT NOT NULL CHECK (type IN ('discount_percent', 'discount_fixed', 'bonus_tokens', 'trial_days')),
    value INT NOT NULL,                -- процент, рубли, токены или дни
    max_uses INT,                      -- NULL = безлимитно
    current_uses INT DEFAULT 0,
    valid_from TIMESTAMPTZ DEFAULT now(),
    valid_until TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE promocode_uses (
    id BIGSERIAL PRIMARY KEY,
    promocode_id UUID REFERENCES promocodes(id),
    user_id UUID REFERENCES users(id),
    applied_at TIMESTAMPTZ DEFAULT now()
);

-- Аудит-лог суперадмина
CREATE TABLE admin_audit_log (
    id BIGSERIAL PRIMARY KEY,
    admin_user_id UUID REFERENCES users(id),
    action TEXT NOT NULL,               -- 'block_user', 'change_plan', 'impersonate', 'grant_tokens', etc.
    target_user_id UUID,
    details JSONB DEFAULT '{}',
    created_at TIMESTAMPTZ DEFAULT now()
);

-- Системные уведомления
CREATE TABLE notifications (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    type TEXT NOT NULL,                 -- 'token_warning', 'token_exhausted', 'payment_failed', 'gardener_proposals', 'system'
    title TEXT NOT NULL,
    message TEXT NOT NULL,
    is_read BOOLEAN DEFAULT false,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMPTZ DEFAULT now()
);

CREATE INDEX notifications_user_unread_idx ON notifications(user_id, is_read)
    WHERE is_read = false;

-- Роль пользователя
ALTER TABLE users ADD COLUMN role TEXT DEFAULT 'user' CHECK (role IN ('user', 'superadmin'));
ALTER TABLE users ADD COLUMN status TEXT DEFAULT 'active' CHECK (status IN ('active', 'blocked', 'deleted'));
ALTER TABLE users ADD COLUMN timezone TEXT DEFAULT 'Europe/Moscow';
ALTER TABLE users ADD COLUMN deleted_at TIMESTAMPTZ;  -- soft delete
```

