## SDK поддержка

```python
# Python SDK — self-editing helpers

agent = client.agents.get("agent_abc")

# Получить tools для передачи в LLM
tools = agent.get_self_editing_tools()
# Возвращает list[dict] в формате OpenAI function calling

# Обработать tool call от LLM
result = agent.execute_tool_call(
    tool_name="core_memory_update",
    arguments={
        "section": "preferences",
        "content": "Предпочитает краткие ответы. Любит примеры с кодом.",
        "reason": "User asked for code examples"
    },
    user_id="user_123"
)

# Полный conversation loop с self-editing
from memoryservice import SelfEditingLoop

loop = SelfEditingLoop(agent=agent, user_id="user_123")

# System prompt автоматически содержит core memory
response = loop.chat(
    user_message="Кстати, я теперь работаю в Яндексе",
    model="anthropic/claude-sonnet-4",  # Через OpenRouter
)
# Агент автоматически:
# 1. Обновит core_memory.user_profile: "...маркетолог в Яндексе"
# 2. Сохранит в recall: "Пользователь сменил работу на Яндекс"
# 3. Ответит пользователю

# Посмотреть что агент изменил в памяти за этот turn
print(loop.last_memory_ops)
# [
#   {"tool": "core_memory_update", "section": "user_profile", "reason": "User mentioned new job"},
#   {"tool": "recall_memory_insert", "content": "Changed job to Yandex", "importance": 0.8}
# ]
```

```typescript
// TypeScript SDK

const agent = await client.agents.get('agent_abc');
const tools = agent.getSelfEditingTools(); // For OpenAI/Anthropic function calling format

const result = await agent.executeToolCall('core_memory_update', {
  section: 'preferences',
  content: 'Prefers brief answers with code examples',
  reason: 'User requested more code examples',
}, { userId: 'user_123' });
