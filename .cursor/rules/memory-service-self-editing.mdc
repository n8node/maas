## Модель данных (дополнения)

```sql
-- migrations/013_self_editing.up.sql

-- Добавить self_editing конфигурацию в agents
ALTER TABLE agents ADD COLUMN self_editing_enabled BOOLEAN DEFAULT false;
ALTER TABLE agents ADD COLUMN core_memory_config JSONB DEFAULT '{
    "sections": ["user_profile", "preferences", "current_context", "important_facts"],
    "max_tokens": 4000
}';

-- Лог self-edit операций (использует существующий action_log)
-- actor = 'self_edit'
-- action = 'core_update', 'core_replace', 'recall_insert', 'archival_insert', 'archival_update', 'archival_delete'
-- rationale = reason из tool call (агент объясняет почему он это делает)

-- Core memory хранится в working_memory:
-- session_id = '__persistent__' (не истекает)
-- key = '__core__'
-- value = JSONB с секциями

-- Статистика self-edit операций
CREATE TABLE self_edit_stats (
    id BIGSERIAL PRIMARY KEY,
    agent_id UUID REFERENCES agents(id) ON DELETE CASCADE,
    scope_user_id TEXT,
    period_start TIMESTAMPTZ NOT NULL,
    period_end TIMESTAMPTZ NOT NULL,
    core_reads INT DEFAULT 0,
    core_updates INT DEFAULT 0,
    core_replaces INT DEFAULT 0,
    recall_searches INT DEFAULT 0,
    recall_inserts INT DEFAULT 0,
    archival_searches INT DEFAULT 0,
    archival_inserts INT DEFAULT 0,
    archival_updates INT DEFAULT 0,
    archival_deletes INT DEFAULT 0,
    created_at TIMESTAMPTZ DEFAULT now()
);
```

