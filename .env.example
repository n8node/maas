# Mnemoniqa — copy to `.env` on the server or locally. Never commit `.env`.

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=info
VERSION=0.3.0

# --- Domain & SSL (Let's Encrypt) ---
DOMAIN=mnemoniqa.com
CERTBOT_EMAIL=erman.ai@yandex.ru

# --- PostgreSQL ---
POSTGRES_USER=mnemoniqa
POSTGRES_PASSWORD=change_me_generate_strong
POSTGRES_DB=mnemoniqa

# --- MySQL (WordPress) ---
MYSQL_ROOT_PASSWORD=change_me_generate_strong
WP_DB_PASSWORD=change_me_generate_strong

# --- Backend auth (Phase 2+) — required for API / JWT / API keys
JWT_SECRET=replace_with_at_least_16_random_chars_use_openssl_rand_hex_32
API_KEY_SALT=replace_with_long_random_string_for_api_key_hashing

# --- OpenRouter (Phase 4+) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Frontend (build-time / runtime public) ---
NEXT_PUBLIC_APP_NAME=Mnemoniqa
NEXT_PUBLIC_API_URL=/api/v1

# --- Workers (future, docker-compose.prod optional services) ---
# WORKER_RAG_CONCURRENCY=4
